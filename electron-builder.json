{
  "appId": "com.hotel.pos-system",
  "productName": "Hotel POS System",
  "npmRebuild": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [],
  "win": {
    "icon": "public/DreamLabsLogoNew.png",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "DreamLabs POS",
    "installerHeaderIcon": "public/DreamLabsLogoNew.png",
    "deleteAppDataOnUninstall": false
  }
}
